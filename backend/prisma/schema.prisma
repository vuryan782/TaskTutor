model peer_feedback {
  id                                      String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  group_session_id                        String               @db.Uuid
  from_user_id                            String               @db.Uuid
  to_user_id                              String?              @db.Uuid
  rating                                  Int?
  comment                                 String?
  is_anonymous                            Boolean?             @default(false)
  created_at                              DateTime?            @default(now()) @db.Timestamptz(6)
  users_peer_feedback_from_user_idTousers users                @relation("peer_feedback_from_user_idTousers", fields: [from_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  group_study_sessions                    group_study_sessions @relation(fields: [group_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_peer_feedback_to_user_idTousers   users?               @relation("peer_feedback_to_user_idTousers", fields: [to_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([from_user_id], map: "idx_feedback_from")
  @@index([group_session_id], map: "idx_feedback_session")
  @@index([to_user_id], map: "idx_feedback_to")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
