generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ai_feedback {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String          @db.Uuid
  session_id          String?         @db.Uuid
  feedback_type       String?         @db.VarChar(50)
  summary             String
  detailed_feedback   Json?
  weak_topics         Json?
  strong_topics       Json?
  suggested_materials String[]        @db.Uuid
  performance_score   Int?
  improvement_tips    Json?
  created_at          DateTime?       @default(now()) @db.Timestamptz(6)
  study_sessions      study_sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_ai_feedback_created")
  @@index([session_id], map: "idx_ai_feedback_session")
  @@index([feedback_type], map: "idx_ai_feedback_type")
  @@index([user_id], map: "idx_ai_feedback_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model calendar_events {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String    @db.Uuid
  title                String    @db.VarChar(255)
  description          String?
  event_type           String?   @db.VarChar(50)
  task_id              String?   @db.Uuid
  start_time           DateTime  @db.Timestamptz(6)
  end_time             DateTime? @db.Timestamptz(6)
  all_day              Boolean?  @default(false)
  is_recurring         Boolean?  @default(false)
  recurrence_rule      String?   @db.VarChar(255)
  external_calendar_id String?   @db.VarChar(255)
  synced_at            DateTime? @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  tasks                tasks?    @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([start_time], map: "idx_calendar_start")
  @@index([event_type], map: "idx_calendar_type")
  @@index([user_id], map: "idx_calendar_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
